# Point Terraform at the local terrastrata mirror (via the Caddy TLS overlay).
# Use it for a run without touching your global config:
#
#   export TF_CLI_CONFIG_FILE=$PWD/terraformrc
#   terraform init
#
# Requires the TLS overlay running and Caddy's internal CA trusted — see
# deploy/local/README.md. Terraform refuses a plaintext (http) mirror URL.
provider_installation {
  network_mirror {
    url = "https://localhost:8443/"
  }
  direct {
    # Let anything not mirrored fall through to the real registry.
    exclude = ["registry.terraform.io/*/*"]
  }
}
